# See https://help.github.com/articles/ignoring-files/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/
/build
next-env.d.ts

# typescript
*.tsbuildinfo

# vercel
.vercel

# env files (keep .env.example only)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# testing / coverage
/coverage
*.lcov

# editor / IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# misc
*.pem
*.tgz

# project-specific
# Generated/source-of-truth assets live in public/assets/. The /assets/ folder
# at the repo root is just where image-gen tools dropped raw outputs — keep it
# out of git (the post-processed copies in public/assets/ are committed).
/assets/

# tsx / node temp files
.cache/
.temp/

# cursor / claude / codex agent transcripts
.cursor/agent-transcripts/
